# Copy this file to .env (or export the vars in your shell) before running in production.

# Required in production. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# "1" to enable debug mode (local dev only). Default is "1" if unset.
DJANGO_DEBUG=0

# Comma-separated list of hostnames the app will serve.
# Required when DJANGO_DEBUG=0.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
